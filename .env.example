# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Database ---
# Local dev uses the natively-installed Postgres. Docker Compose overrides the host.
DATABASE_URL=postgresql+psycopg://ec_user:ec_pass@localhost:5432/email_context

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# 32+ char random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Encryption at rest (EmailSummary payload) ---
# 32-byte key, base64-encoded (AES-256). Generate:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
SUMMARY_ENCRYPTION_KEY=
SUMMARY_ENCRYPTION_KEY_VERSION=1

# --- LLM ---
# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# If true, the summarization service returns a deterministic stub instead of
# calling Gemini. Useful for tests, demos, and running without a key.
LLM_STUB_MODE=false

# --- Cache TTL ---
SUMMARY_CACHE_TTL_SECONDS=3600

# --- App ---
ENV=development
LOG_LEVEL=INFO
