# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Database ---
# Local dev uses the natively-installed Postgres. Docker Compose overrides the host.
DATABASE_URL=postgresql+psycopg://ec_user:ec_pass@localhost:5432/email_context

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# 32+ char random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Encryption at rest (EmailSummary payload) ---
# 32-byte key, base64-encoded (AES-256). Generate:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
SUMMARY_ENCRYPTION_KEY=
SUMMARY_ENCRYPTION_KEY_VERSION=1

# --- LLM (pluggable behind the LLMProvider interface) ---
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# If true (or if LLM_API_KEY is empty), summarization returns a deterministic
# stub instead of calling the provider. Useful for tests, demos, and no-key runs.
LLM_STUB_MODE=false
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=30
# Sampling temperature for summarization. 0 keeps summaries faithful to the
# emails and reproducible; raise it only if you want more varied phrasing.
LLM_TEMPERATURE=0
# Model used by the opt-in LLM-as-judge eval (`make eval`); defaults to gpt-4o.
# JUDGE_MODEL=gpt-4o

# --- Context scaling ---
# Safety cap on the summarization prompt (rough ~4 chars/token heuristic). Well
# under gpt-4o-mini's 128k window; oversized histories are truncated oldest-first.
SUMMARY_MAX_INPUT_TOKENS=60000
# Once a client has >= INCREMENTAL_MIN_PRIOR_EMAILS analyzed emails and a prior
# summary, a refresh feeds only the NEW emails (refine) instead of the whole
# history — keeps cost/latency flat as threads grow. Set false to always do a
# full pass.
INCREMENTAL_REFRESH=true
INCREMENTAL_MIN_PRIOR_EMAILS=20

# --- Cache TTL ---
SUMMARY_CACHE_TTL_SECONDS=3600

# --- Observability (OpenTelemetry tracing) ---
# Off by default: the app runs with no collector. Set OTEL_ENABLED=true and an
# OTLP endpoint to ship traces (Jaeger/Tempo/Datadog/Honeycomb). Or set
# OTEL_CONSOLE_EXPORT=true to print spans to stdout with no backend.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=email-context
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_CONSOLE_EXPORT=false

# --- App ---
ENV=development
LOG_LEVEL=INFO
